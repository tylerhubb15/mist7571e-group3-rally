# Copy this file to .env and fill in real values. NEVER commit .env.
# Supabase (Phase 2 — backend wiring)
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Maps JS API key (Courts tab). Restrict it to your dev/prod
# domains in Google Cloud Console — this key ships to the browser.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OpenAI key goes in the SERVER-SIDE proxy env (Netlify/Vercel dashboard),
# NEVER in this file and NEVER in client code.
